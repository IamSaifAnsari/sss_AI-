{
  "name": "neuronstack-ai",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "description": "NeuronStack AI — Vite + React Router frontend with Node + Express + SQLite backend.",
  "scripts": {
    "dev": "concurrently -n server,vite -c green,cyan \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "vite",
    "server": "node server/index.js",
    "build": "vite build",
    "preview": "vite preview --port 5173"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.6.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "jsonwebtoken": "^9.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "vite": "^5.4.10"
  }
}
